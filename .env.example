# 后端环境变量配置

# Neo4j 数据库配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# AI 配置
# 可选: ollama / openai
AI_PROVIDER=ollama
AI_TIMEOUT=120

# 本地 Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# 在线 OpenAI 兼容接口（AI_PROVIDER=openai 时生效）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODELS=

# 抽取扫描页上限（先读取 PDF 总页数，再取 min(总页数, 该值)）
MAX_SCAN_PAGES=40

# 抽取调试模式：按固定页区间抽取（避免随机抽样）
# off/on
EXTRACT_CHAPTER_MODE=off
# 开始页（从 1 开始）
EXTRACT_PAGE_START=1
# 结束页（包含该页）
EXTRACT_PAGE_END=5

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# 日志配置
LOG_LEVEL=INFO
